# LLM API Proxy Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED (for basic functionality)
# ============================================

# No API keys required for basic operation!
# The proxy works out-of-the-box with free providers (Groq, G4F)

# ============================================
# OPTIONAL PROVIDERS (add for more fallbacks)
# ============================================

# GitHub Models (Free but rate-limited)
# Get your token at: https://github.com/settings/tokens
# GITHUB_MODELS_API_BASE=https://models.github.ai/inference
# GITHUB_MODELS_API_KEY=ghp_your_token_here

# Cloudflare Workers AI (10,000 neurons/day free)
# Get credentials at: https://dash.cloudflare.com/
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# Google Gemini API (Free tier available)
# Get your key at: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_key_here

# ============================================
# WEB SEARCH (Optional)
# ============================================

# DuckDuckGo (FREE - No key required)
# Works out of the box!

# Brave Search (2,000 free requests/month)
# Get your key at: https://api.search.brave.com/app/keys
# BRAVE_API_KEY=your_brave_api_key_here

# Tavily Search (1,000 free searches/month)
# Get your key at: https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# SERVER CONFIGURATION (Optional)
# ============================================

# Server host and port (defaults shown)
# HOST=0.0.0.0
# PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
