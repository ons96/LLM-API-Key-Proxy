@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    Lifecycle manager for the FastAPI app.
    Handles startup and shutdown events.
    """
    global _start_time
    import importlib
    import proxy_app.router_core as router_core
    importlib.reload(router_core)

    # Initialize router
    initialize_router()
    print(f"✓ Router initialized")

    # Initialize health checker
    _health_checker = HealthChecker()
    app.state.health_checker = _health_checker
    print(f"✓ Health checker initialized")

    # Background tasks can be added here if needed
    yield

    # Cleanup on shutdown
    print("🛑 Shutting down...")


# Create FastAPI app
app = FastAPI(
    title="Mirro Proxy",
    description="Multi-Provider AI Gateway with Automatic Key Rotation",
    version="1.0.0",
    lifespan=lifespan,
)

