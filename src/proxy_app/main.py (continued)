@app.get("/health")
async def health_check(request: Request):
    """Health check endpoint."""
    # Get correlation ID from request state (set by middleware)
    correlation_id = getattr(request.state, "correlation_id", "unknown")
    
    health_checker = request.app.state.health_checker
    health_status = await health_checker.get_health_status()
    
    return {
        "status": "healthy" if health_status["is_healthy"] else "degraded",
        "correlation_id": correlation_id,
        "details": health_status
    }


@app.get("/v1/models")
async def list_models(
    request: Request,
    api_key: str = Depends(require_api_key)
):
    """List available models."""
    # Get correlation ID
    correlation_id = getattr(request.state, "correlation_id", "unknown")
    
    # Use the model's info service
    from rotator_library.model_info_service import get_model_info_service
    
    model_info_service = get_model_info_service()
    models = model_info_service.get_all_models()
    
    # Convert to ModelCard format
    model_cards = [
        ModelCard(
            id=model_id,
            owned_by=info.get("owned_by", "unknown")
        )
        for model_id, info in models.items()
    ]
    
    return {
        "object": "list",
        "data": [m.model_dump() for m in model_cards]
    }


@app.get("/v1/models/{model_id}")
async def get_model(
    model_id: str,
    request: Request,
    api_key: str = Depends(require_api_key)
):
    """Get specific model info."""
    correlation_id = getattr(request.state, "correlation_id", "unknown")
    
    from rotator_library.model_info_service import get_model_info_service
    
    model_info_service = get_model_info_service()
    model_info = model_info_service.get_model_info(model_id)
    
    if not model_info:
        raise HTTPException(status_code=404, detail="Model not found")
    
    # Convert to EnrichedModelCard
    card = EnrichedModelCard(
        id=model_id,
        owned_by=model_info.get("owned_by", "unknown"),
        input_cost_per_token=model_info.get("input_cost_per_token"),
        output_cost_per_token=model_info.get("output_cost_per_token"),
        max_input_tokens=model_info.get("max_input_tokens"),
        max_output_tokens=model_info.get("max_output_tokens"),
        context_window=model_info.get("context_window"),
    )
    
    return card.model_dump()


@app.post("/v1/chat/completions")
async def chat_completions(
    request: Request,
    api_key: str = Depends(require_api_key),
    logger: DetailedLogger = Depends(get_detailed_logger)
):
    """
    Handle chat completion requests.
    """
    # Get correlation ID from request state (set by middleware)
    correlation_id = getattr(request.state, "correlation_id", "unknown")
    
    # Enable request logging if flag is set
    if args.enable_request_logging:
        request_start = time.time()
    
    try:
        # Parse request body
        request_data = await request.json()
        
        # Handle the request
        response = await _handle_chat_completion(
            request_data,
            logger,
            correlation_id,
            request
        )
        
        # Log if enabled
        if args.enable_request_logging:
            duration_ms = (time.time() - request_start) * 1000
            model = _extract_model_from_request(request_data)
            log_request_to_console(
                method="POST",
                path="/v1/chat/completions",
                status_code=200,
                duration_ms=duration_ms,
                model=model
            )
            log_request_to_file(
                method="POST",
                path="/v1/chat/completions",
                status_code=200,
                duration_ms=duration_ms,
                request_body=request_data,
                response_body=response,
                model=model,
                extra={"correlation_id": correlation_id}
            )
        
        return response
        
    except HTTPException:
        raise
    except Exception as e:
        if args.enable_request_logging:
            duration_ms = (time.time() - request_start) * 1000
            log_request_to_console(
                method="POST",
                path="/v1/chat/completions",
                status_code=500,
                duration_ms=duration_ms,
                error=str(e)
            )
        
        logger.log_error(e, {"correlation_id": correlation_id})
        raise HTTPException(status_code=500, detail=str(e))


