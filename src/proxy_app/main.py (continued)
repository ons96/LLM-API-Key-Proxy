# REQUEST PROCESSING HELPERS
# ============================================================
def _extract_model_from_request(data: dict) -> Optional[str]:
    """Extract model name from various request formats."""
    return data.get("model")


async def _handle_chat_completion(
    request_data: dict,
    logger: DetailedLogger,
    correlation_id: str,
    request: Request
):
    """
    Handle chat completion request with full correlation ID tracking.
    """
    from proxy_app.router_wrapper import get_router
    
    model = _extract_model_from_request(request_data)
    start_time = time.time()
    
    logger.log_request_start(
        method="POST",
        endpoint="/v1/chat/completions",
        model=model,
        extra={"correlation_id": correlation_id}
    )
    
    try:
        router = get_router()
        # Pass correlation_id to the router
        response = await router.handle_chat_completion(
            request_data,
            correlation_id=correlation_id
        )
        
        duration_ms = (time.time() - start_time) * 1000
        logger.log_request_end(
            method="POST",
            endpoint="/v1/chat/completions",
            status_code=200,
            duration_ms=duration_ms,
            extra={"correlation_id": correlation_id}
        )
        
        return response
        
    except Exception as e:
        duration_ms = (time.time() - start_time) * 1000
        logger.log_error(e, {
            "endpoint": "/v1/chat/completions",
            "model": model,
            "correlation_id": correlation_id
        })
        logger.log_request_end(
            method="POST",
            endpoint="/v1/chat/completions",
            status_code=500,
            duration_ms=duration_ms,
            extra={"correlation_id": correlation_id, "error": str(e)}
        )
        raise


